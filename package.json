{
  "name": "bedrock-advpo-agent-skill",
  "version": "1.0.0",
  "description": "An agent skill for [Kiro IDE](https://kiro.dev) that lets AI coding agents create, manage, and analyze [Amazon Bedrock Advanced Prompt Optimization](https://docs.aws.amazon.com/bedrock/latest/userguide/advanced-prompts.html) jobs through a guided conversational workflow.",
  "main": "index.js",
  "scripts": {
    "eval": "npx agent-skills-eval --config agent-skills-eval.yaml",
    "eval:no-baseline": "npx agent-skills-eval --config agent-skills-eval.yaml --no-baseline",
    "eval:proxy": "litellm --config litellm-config.yaml --port 4000",
    "test": "python -m pytest tests/ -v"
  },
